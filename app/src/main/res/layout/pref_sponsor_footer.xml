<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:paddingTop="24dp"
    android:paddingBottom="24dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

  <TextView
      android:id="@+id/sponsorLabel"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/sponsored_by"
      android:textSize="16sp"
      android:alpha="0.75"
      android:paddingBottom="12dp" />

  <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">

    <ImageView
        android:id="@+id/sponsorLogo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ksa_logo"
        android:contentDescription="@string/sponsored_by" />

    <ImageView
        android:id="@+id/wisdomLogo"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:adjustViewBounds="true"
        android:src="@drawable/wisdom_logo"
        android:contentDescription="@string/sponsored_by" />

  </LinearLayout>

  <TextView
      android:id="@+id/sponsorName"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="Karnataka Salafi Association Mangaluru ®️ Wisdom Islamic Organization"
      android:textSize="16sp"
      android:gravity="center"
      android:paddingTop="12dp" />

</LinearLayout>
